---
import { Image } from "astro:assets";
const { title, logo, link } = Astro.props;
---

<a href={link} target="_blank" rel="noopener noreferrer" class="language-button">
  <Image src={logo} alt="logo"/>
  <p>{title}</p>
</a>

<style lang="scss">
  img {
    width: 1.5rem;
    height: 1.5rem;
  }

  a {
    text-decoration: none;
    color: inherit;
  }

  // add more styling later
  .language-button {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.75rem 1rem;
    border: 2px solid black;
    border-radius: 2rem;
  }
</style>