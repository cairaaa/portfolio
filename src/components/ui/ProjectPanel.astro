---
import { Image } from "astro:assets";

const { title, image } = Astro.props;
---

<div class="project-panel border fade-wrapper">
  <p class="project-title">{title}</p>
  <Image src={image} alt="project showcase" class="project-image" />
  <p class="project-description">
    <slot />
  </p>
</div>

<style lang="scss">
  img {
    width: 100%;
    height: auto;
    object-fit: contain;
    flex-shrink: 0;
  }

  .project-panel {
    min-width: 80%;
    display: grid;
    grid-template-columns: 50% auto;
    grid-template-rows: 1.5rem auto;
    column-gap: 2rem;
    row-gap: 0.75rem;
    padding: 2rem;
    box-shadow: 2px 2px 8px $border-colour;
    border-radius: 8px;
  }

  .project-title {
    grid-row: 1;
    grid-column: 2;
    text-align: center;
    font-size: 1.25rem;
    font-weight: 700;
    color: $heading-colour;
  }

  .project-image {
    grid-row: 1 / 3;
    grid-column: 1;
    justify-self: center;
    align-self: center;
  }

  .project-description {
    grid-row: 2;
    grid-column: 2;
  }

  @media (min-width: 1281px) {
    .project-panel {
      grid-template-columns: 40% auto;
    }
  }

  @media (max-width: 700px) {
    .project-panel {
      grid-template-columns: 1fr;
      grid-template-rows: auto auto auto;
      row-gap: 1.5rem;
    }

    .project-title {
      grid-column: 1;
      grid-row: 1;
      text-align: center;
    }

    .project-image {
      grid-column: 1;
      grid-row: 2;
      justify-self: center;
      width: 80%;
    }

    .project-description {
      grid-column: 1;
      grid-row: 3;
    }
  }
</style>